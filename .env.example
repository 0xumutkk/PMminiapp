# Base Mini App public URL (used by manifest `frame.homeUrl`)
NEXT_PUBLIC_MINI_APP_URL=https://your-miniapp-url.com

# Base RPC endpoint
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_APP_ID=

# Base Builder Code (from base.dev)
NEXT_PUBLIC_BASE_BUILDER_CODE=
# Base Build ownership data for manifest import/management
BASE_BUILDER_OWNER_ADDRESS=
BASE_BUILDER_ALLOWED_ADDRESSES=

# Base Mini App manifest presentation
NEXT_PUBLIC_APP_NAME=Pulse Markets
NEXT_PUBLIC_ICON_URL=https://your-miniapp-domain.com/icon.png
NEXT_PUBLIC_SPLASH_IMAGE_URL=https://your-miniapp-domain.com/Splash.png
NEXT_PUBLIC_SPLASH_BG="#0b1020"
NEXT_PUBLIC_APP_SUBTITLE=Live prediction markets
NEXT_PUBLIC_APP_DESCRIPTION=Live 15m markets on Base
NEXT_PUBLIC_PRIMARY_CATEGORY=finance
NEXT_PUBLIC_APP_TAGS=markets,prediction,base
NEXT_PUBLIC_SCREENSHOT_URLS=https://your-miniapp-domain.com/screenshot-1.png,https://your-miniapp-domain.com/screenshot-2.png
NEXT_PUBLIC_HERO_IMAGE_URL=https://your-miniapp-domain.com/hero.png
NEXT_PUBLIC_APP_TAGLINE=Trade in seconds
NEXT_PUBLIC_OG_TITLE=Pulse Markets
NEXT_PUBLIC_OG_DESCRIPTION=Live 15-minute markets on Base.
NEXT_PUBLIC_OG_IMAGE_URL=https://your-miniapp-domain.com/og.png
NEXT_PUBLIC_NOINDEX=false

# Optional webhook for notifications
MINI_APP_WEBHOOK_URL=

# SIWE message freshness & session validation
AUTH_SESSION_SECRET=replace-with-a-random-secret
AUTH_SIWE_MAX_AGE_SECONDS=600
AUTH_SESSION_MAX_AGE_SECONDS=604800
AUTH_CLOCK_SKEW_SECONDS=30
AUTH_RATE_LIMIT_PER_MINUTE=30

# Limitless API
# Base URL only (client automatically normalizes accidental `/api-v1` suffix)
LIMITLESS_API_BASE_URL=https://api.limitless.exchange
# Max allowed by API is 25
LIMITLESS_ACTIVE_PAGE_LIMIT=25
LIMITLESS_POLL_INTERVAL_MS=3000

# Phase 3 transaction contracts
# Optional override. Default is Base USDC.
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Optional fallback if market payload does not expose venue.exchange.
LIMITLESS_TRADE_CONTRACT_ADDRESS=
# Optional override if market payload does not expose trade signature metadata.
LIMITLESS_TRADE_FUNCTION_SIGNATURE=buy(uint256,uint256,uint256)
# amount=USDC to spend, outcome-index=0 for YES/1 for NO, zero=minOutcomeTokensToBuy (0 = market order)
LIMITLESS_TRADE_ARG_MAP=amount,outcome-index,zero
# Sell intent (defaults to same trade contract if not set)
LIMITLESS_SELL_CONTRACT_ADDRESS=
LIMITLESS_SELL_FUNCTION_SIGNATURE=sellShares(bytes32,bool,uint256)
LIMITLESS_SELL_ARG_MAP=market,side,amount
# Usually false; set true only if your sell flow needs USDC approve.
SELL_REQUIRE_USDC_APPROVE=false
# Redeem intent (settled markets)
LIMITLESS_REDEEM_CONTRACT_ADDRESS=
LIMITLESS_REDEEM_FUNCTION_SIGNATURE=redeemShares(bytes32,bool)
LIMITLESS_REDEEM_ARG_MAP=market,side
# Comma-separated actions requiring a USDC approve call.
TRADE_APPROVE_ACTIONS=buy
USDC_DECIMALS=6
TRADE_MIN_USDC=1
TRADE_MAX_USDC=1000

# Phase 5 security and beta rollout
API_RATE_LIMIT_ENABLED=true
MARKETS_RATE_LIMIT_PER_MINUTE=120
MARKETS_STREAM_RATE_LIMIT_PER_MINUTE=20
TRADE_INTENT_RATE_LIMIT=30
# true  => always require SIWE-backed auth token
# false => disable token requirement
# if unset, production defaults to true and development defaults to false
TRADE_AUTH_REQUIRED=false
BETA_MODE=false
BETA_ALLOWLIST_ADDRESSES=

# Redis (optional but recommended for Phase 2)
REDIS_URL=redis://localhost:6379
